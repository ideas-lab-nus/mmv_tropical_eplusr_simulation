    PCM_Window,              !- Name
    AfterPredictorBeforeHVACManagers,  !- EnergyPlus Model Calling Point
    AdjustAllListedWindows_Program;  !- Program Name 1


!-   ===========  ALL OBJECTS IN CLASS: ENERGYMANAGEMENTSYSTEM:PROGRAM ===========

EnergyManagementSystem:Program,
    AdjustCoolSetpoint,      !- Name
    IF (NV_Enable_SchedVal == 1) && (OutdoorTemp < 30) && (WindSpeed_Sensor <= 20) && (Rain_Sensor == 0),  !- Program Line 1
    SET ThermostatCoolSet_Actuator = 32.0,  !- Program Line 2
    ELSE,                    !- A4
    SET ThermostatCoolSet_Actuator = 27.0,  !- A5
    ENDIF;                   !- A6

EnergyManagementSystem:Program,
    AdjustAllListedWindows_Program,  !- Name
    IF (NV_Enable_SchedVal == 1) && (OutdoorTemp < 30),  !- Program Line 1
    SET Window_ldf_unit1_FrontRow_BottomFloor_Actuator = ExWall_Open,  !- Program Line 2
    SET Window_ldf_unit2_FrontRow_BottomFloor_Actuator = ExWall_Open,  !- A4
    SET Window_sdr_unit3_FrontRow_BottomFloor_Actuator = ExWall_Open,  !- A5
    SET Window_sdl_unit3_FrontRow_BottomFloor_Actuator = ExWall_Open,  !- A6
    SET Window_ldf_unit3_FrontRow_BottomFloor_Actuator = ExWall_Open,  !- A7
    SET Window_ldb_unit1_BackRow_BottomFloor_Actuator = ExWall_Open,  !- A8
    SET Window_ldb_unit2_BackRow_BottomFloor_Actuator = ExWall_Open,  !- A9
    SET Window_sdr_unit3_BackRow_BottomFloor_Actuator = ExWall_Open,  !- A10
    SET Window_sdl_unit3_BackRow_BottomFloor_Actuator = ExWall_Open,  !- A11
    SET Window_ldb_unit3_BackRow_BottomFloor_Actuator = ExWall_Open,  !- A12
